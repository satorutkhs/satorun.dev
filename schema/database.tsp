import "@typespec/compiler";

using TypeSpec;

@doc("Firestore database schema for satorun.dev")
namespace SatorunDev.Database;

@doc("Represent a blog post article in Firestore blog_posts collection")
model BlogPost {
  @doc("Unique document ID generated by Firestore")
  id: string;

  @doc("Title of the blog post")
  title: string;

  @doc("URL-friendly slug for routing (e.g. fun-project-learning)")
  slug: string;

  @doc("Short description or summary of the post")
  excerpt: string;

  @doc("Markdown content of the article")
  content: string;

  @doc("URL of the cover image stored in Storage or external CDN")
  coverImageUrl: string;

  @doc("List of tags associated with the post")
  tags: string[];

  @doc("Publishing status of the post")
  status: "draft" | "published";

  @doc("Display name of the author")
  authorName: string;

  @doc("Creation date of the article")
  createdAt: utcDateTime;

  @doc("Last update date of the article")
  updatedAt: utcDateTime;

  @doc("Total number of page views")
  viewCount: int32;
}

@doc("Represent a research material in Firestore research_materials collection")
model ResearchMaterial {
  @doc("Unique document ID generated by Firestore")
  id: string;

  @doc("Title of the research material or slide")
  title: string;

  @doc("Detailed description of the material contents")
  description: string;

  @doc("File or material type classification")
  type: "pdf" | "slide" | "paper" | "poster";

  @doc("Download URL of the file stored in Firebase Storage")
  fileUrl: string;

  @doc("Optional preview image URL")
  thumbnailUrl?: string;

  @doc("Tags for categorizing research topics")
  tags: string[];

  @doc("Access control: true for public access, false for authenticated lab members only")
  isPublic: boolean;

  @doc("Upload date of the material")
  createdAt: utcDateTime;

  @doc("Last modification date")
  updatedAt: utcDateTime;

  @doc("Size of the file in bytes")
  fileSize: int64;
}
